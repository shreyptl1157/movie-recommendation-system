# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_WORKERS=4

# Database Configuration
DATABASE_URL=postgresql://postgres:password@db:5432/movie_recommender
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# Model Configuration
SVD_N_FACTORS=100
SVD_N_EPOCHS=20
SVD_LR_ALL=0.01
SVD_REG_ALL=0.02
SVD_RANDOM_STATE=42

# Content-Based Configuration
CONTENT_MIN_DF=5
CONTENT_MAX_DF=0.8
CONTENT_MAX_FEATURES=5000

# Collaborative Configuration
COLLAB_K_NEIGHBORS=10
COLLAB_MIN_COMMON_ITEMS=2

# Data Configuration
DATASET=movielens-1m
DATA_PATH=./data
DATA_DOWNLOAD=true

# Feature Engineering
FEATURE_ENGINEER_ENABLE=true
FEATURE_ENGINEER_GENRES=true
FEATURE_ENGINEER_TEMPORAL=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_FORMAT=json

# Evaluation
EVAL_K_VALUES=[5,10,20]
EVAL_THRESHOLD=3.5

# Performance
MAX_RECOMMENDATIONS=100
DEFAULT_N_RECOMMENDATIONS=10
RECOMMENDATION_TIMEOUT=30

# Security
SECRET_KEY=your-secret-key-change-this
ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=1440

# Environment
ENVIRONMENT=development
