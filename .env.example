# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/movie_recommendation
DATABASE_ECHO=False

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True
API_WORKERS=4

# Model Configuration
MODEL_TYPE=hybrid
CF_ALGORITHM=svd
N_FACTORS=50
N_EPOCHS=100
BATCH_SIZE=32

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Data Configuration
DATA_PATH=data/
MODEL_PATH=data/models/

# Application Configuration
APP_NAME=Movie Recommendation System
APP_VERSION=1.0.0
SECRET_KEY=your-secret-key-here
